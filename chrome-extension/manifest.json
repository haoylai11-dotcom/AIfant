{
  "manifest_version": 3,
  "name": "DYKS Analyzer - 短视频数据提取",
  "version": "1.0",
  "description": "一键提取抖音/快手视频页面公开显示的标题、作者、点赞、评论、播放数,发送到研究数据管理工具",
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["http://localhost:8000/*", "http://127.0.0.1:8000/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "提取视频数据"
  },
  "content_scripts": [
    {
      "matches": ["*://*.douyin.com/*", "*://*.kuaishou.com/*", "*://*.iesdouyin.com/*"],
      "js": ["extractor.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
