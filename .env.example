# Database
DATABASE_URL=sqlite+aiosqlite:///./dyks_data.db
# For PostgreSQL later:
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/dyks_analyzer

# Security
SECRET_KEY=change-me-to-a-random-secret-string
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440

# File storage
MEDIA_STORAGE_PATH=./media_storage

# Research configuration
PROJECT_NAME=抖音-快手AI数字人短视频内容分析
RESEARCH_TEAM=Research Team Name
INSTITUTION=Institution Name

# Logging
LOG_LEVEL=INFO

# External APIs (Phase 2)
# DOUYIN_CLIENT_KEY=
# DOUYIN_CLIENT_SECRET=
# KUAISHOU_APP_ID=
# KUAISHOU_APP_SECRET=

# MediaCrawler
MEDIACRAWLER_BASE_URL=http://localhost:8001
MEDIACRAWLER_TIMEOUT=30.0
